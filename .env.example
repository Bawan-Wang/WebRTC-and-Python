# Source this file before starting the backend if you want to override defaults.
# Example: set -a && source .env && set +a && python -m backend.app

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=0
LOG_LEVEL=INFO
BACKEND_CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ICE_GATHERING_TIMEOUT=5
