# Copy to .env.local for frontend-specific overrides.

# Leave empty in local development to use the Vite proxy.
VITE_API_BASE_URL=

# Override the backend target used by the Vite dev proxy when frontend and backend
# are not running on the same machine.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# Optional: JSON array or comma-separated list of STUN/TURN URLs.
# VITE_WEBRTC_ICE_SERVERS=["stun:stun.l.google.com:19302"]